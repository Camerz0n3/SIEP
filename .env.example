# ============================================
# SIEP — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API Security (bearer token for /api/* and /cron/* routes)
API_SECRET=

# Groq (LLM brain — free tier)
GROQ_API_KEY=

# Google OAuth2 (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PERSONAL_REFRESH_TOKEN=
GOOGLE_KOJA_REFRESH_TOKEN=

# Data directory (SQLite database stored here — persists on Railway with a volume)
DATA_DIR=./data

# App
NODE_ENV=development
PORT=3000
TIMEZONE=Europe/Zurich
VERBIER_LAT=46.0967
VERBIER_LNG=7.2286
