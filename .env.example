# ============================================
# SIEP — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Twilio (WhatsApp + SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
CAMERON_PHONE_NUMBER=whatsapp:+41XXXXXXXXX

# Google OAuth2 (Calendar + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PERSONAL_REFRESH_TOKEN=
GOOGLE_KOJA_REFRESH_TOKEN=

# Google Gemini (AI brain — free tier)
GEMINI_API_KEY=

# OpenAI (Whisper for voice notes)
OPENAI_API_KEY=

# Data directory (SQLite database stored here — persists on Railway with a volume)
DATA_DIR=./data

# App
NODE_ENV=development
PORT=3000
TIMEZONE=Europe/Zurich
VERBIER_LAT=46.0967
VERBIER_LNG=7.2286
